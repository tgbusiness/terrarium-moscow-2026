# ==============================================================================
# КОНФИГУРАЦИОННЫЙ ФАЙЛ ПЕРЕМЕННЫХ ОКРУЖЕНИЯ (.env.example)
# [VERIFY-2026] Актуально для развертывания в связке Vercel + Railway + Telegram
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. НАСТРОЙКИ TELEGRAM БОТА (Railway / Replit)
# ------------------------------------------------------------------------------
# Получите токен у @BotFather в Telegram
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ_example"

# Ваш личный Telegram User ID (или ID группы/канала) для получения уведомлений о лидах
# Можно узнать через бота @userinfobot или @GetIDs Bot
MASTER_TELEGRAM_ID="123456789"

# ------------------------------------------------------------------------------
# 2. НАСТРОЙКИ БАЗЫ ДАННЫХ POSTGRESQL (Railway / Supabase)
# ------------------------------------------------------------------------------
# Ссылка для подключения к PostgreSQL (выдается в Railway -> Postgres -> Connect)
DATABASE_URL="postgresql://postgres:password@viaduct.proxy.rlwy.net:65432/railway"

# ------------------------------------------------------------------------------
# 3. НАСТРОЙКИ GOOGLE SHEETS (Альтернативная или комбинированная CRM)
# ------------------------------------------------------------------------------
# ID Google Таблицы (находится в URL между /d/ и /edit)
GOOGLE_SHEET_ID="1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgvE2upms"

# Имя рабочей страницы (вкладки) в таблице для записей лидов
GOOGLE_SHEET_NAME="Leads & Orders"

# JSON-ключ сервисного аккаунта Google (создается в Google Cloud Console)
# В Vercel / Railway можно вставить как одну строку
GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", "project_id": "terrarium-crm-2026", "private_key": "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n", "client_email": "bot@terrarium-crm-2026.iam.gserviceaccount.com"}'

# ------------------------------------------------------------------------------
# 4. НАСТРОЙКИ ЛЕНДИНГА И БЭКЕНДА (Vercel / Railway)
# ------------------------------------------------------------------------------
# URL API для отправки заявок с фронтенда (по умолчанию использует Next.js API)
NEXT_PUBLIC_API_URL="/api/contact"

# Секретный токен для защиты API от несанкционированного доступа
API_SECRET_TOKEN="your_super_secret_token_for_api_2026"

# Порт для локального запуска или Node.js бэкенда на Railway
PORT=8080
